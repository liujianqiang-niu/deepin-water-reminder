#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DBUILD_TESTS=OFF

override_dh_auto_install:
	dh_auto_install
	install -D -m 0644 debian/deepin-water-reminder.desktop \
		debian/deepin-water-reminder/usr/share/applications/deepin-water-reminder.desktop
	install -D -m 0644 resources/icons/deepin-water-reminder.svg \
		debian/deepin-water-reminder/usr/share/icons/hicolor/scalable/apps/deepin-water-reminder.svg

override_dh_strip:
	dh_strip --dbgsym-migration='deepin-water-reminder-dbgsym (<< 1.0.0~)'
